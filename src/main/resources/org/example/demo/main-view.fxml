<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.demo.controller.MainController">

    <left>
        <VBox spacing="15.0" style="-fx-background-color: #2c3e50; -fx-pref-width: 200;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="10.0" right="10.0" top="20.0" />
            </padding>
            <children>
                <Label text="Bibliothèque" style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;">
                    <VBox.margin><Insets bottom="20.0" /></VBox.margin>
                </Label>

                <Button fx:id="btnLivres" maxWidth="1.7976931348623157E308" text=" Gestion des Livres" style="-fx-background-color: #34495e; -fx-text-fill: white;" onAction="#afficherVueLivres"/>
                <Button fx:id="btnMembres" maxWidth="1.7976931348623157E308" text=" Gestion des Membres" style="-fx-background-color: #34495e; -fx-text-fill: white;" onAction="#afficherVueMembres"/>
                <Button fx:id="btnEmprunts" maxWidth="1.7976931348623157E308" text=" Emprunts &amp; Retours" style="-fx-background-color: #34495e; -fx-text-fill: white;" onAction="#afficherVueEmprunts"/>
            </children>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #ecf0f1;" BorderPane.alignment="CENTER">
            <children>
                <Label text="Bienvenue dans l'application de Gestion de Bibliothèque" style="-fx-font-size: 16; -fx-text-fill: #7f8c8d;" />
            </children>
        </StackPane>
    </center>

</BorderPane>