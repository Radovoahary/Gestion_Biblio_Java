<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="30.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.demo.controller.DashboardController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
    <children>
        <VBox spacing="5.0">
            <children>
                <Label text="Tableau de Bord" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                <Label text="Voici l'état actuel de votre bibliothèque." style="-fx-font-size: 14; -fx-text-fill: #7f8c8d;" />
            </children>
        </VBox>

        <HBox spacing="20.0" maxWidth="Infinity">
            <children>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="10.0" style="-fx-background-color: #ffffff; -fx-padding: 20; -fx-border-radius: 5;">
                    <Label text="Livres Enregistrés" style="-fx-text-fill: #7f8c8d;" />
                    <Label fx:id="lblTotalLivres" text="--" style="-fx-font-size: 24; -fx-font-weight: bold;" />
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="10.0" style="-fx-background-color: #ffffff; -fx-padding: 20; -fx-border-radius: 5;">
                    <Label text="Adhérents Actifs" style="-fx-text-fill: #7f8c8d;" />
                    <Label fx:id="lblTotalMembres" text="--" style="-fx-font-size: 24; -fx-font-weight: bold;" />
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="10.0" style="-fx-background-color: #ffffff; -fx-padding: 20; -fx-border-radius: 5;">
                    <Label text="Emprunts en cours" style="-fx-text-fill: #7f8c8d;" />
                    <Label fx:id="lblEmpruntsActifs" text="--" style="-fx-font-size: 24; -fx-font-weight: bold;" />
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>